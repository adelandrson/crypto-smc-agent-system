# ============================================================
# crypto-smc-agent-system — konfigurasi. Salin ke .env lalu isi.
# JANGAN commit .env (berisi secret). Sistem PEMBANDING (metodologi SMC/FVG),
# berjalan berdampingan dengan crypto-quant-agent (port/DB terpisah).
# ============================================================

# --- API keys ---
CMC_API_KEY=            # coinmarketcap.com/api (Basic free) — WAJIB utk universe/tier-list
ADMIN_TOKEN=            # opsional: token rahasia utk panel Admin web. Kosong = admin mati

# --- Storage ---
DATABASE_URL=sqlite:///crypto_smc.db
# Live/Postgres: postgresql+psycopg://user:pass@host:5432/cryptosmc

# --- LLM (OPSIONAL — kosong by default, diisi manual atau lewat framework agent) ---
LLM_BASE_URL=           # mis. http://localhost:20128/v1 | https://openrouter.ai/api/v1
LLM_MODEL_ORCH=         # otak orchestrator (reasoning). Kosong = belum dikonfigurasi
LLM_MODEL_LIGHT=        # agent ringan (tugas murah)

# --- Universe ---
MARKETCAP_FLOOR=300000000   # $300M — sesuai instruksi user, ubah bila perlu

# --- Telegram (OPSIONAL — bot no-op graceful kalau kosong, lihat src/telegram/bot.py) ---
# 1) Buat bot via @BotFather di Telegram -> dapat token, isi di bawah.
# 2) Kirim 1 pesan ke bot -> ia akan balas "Chat ID Anda: X, belum diotorisasi" -> salin X ke sini.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=   # daftar chat_id dipisah koma, mis. "111222333,444555666"; kosong = terbuka (dev)
